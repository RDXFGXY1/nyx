{
  "manifest_version": 3,
  "name": "nyx",
  "version": "1.4.0",
  "description": "Glass Nyx: link groups, command mode (>), Alt+D dock, image/video wallpaper with auto colors.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [
    "contextMenus",
    "bookmarks",
    "storage",
    "tabs",
    "webNavigation",
    "history",
    "topSites"
  ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "js/stashCore.js",
        "js/content.js",
        "js/mediaControl.js",
        "js/vaultContent.js",
        "js/snippets.js",
        "js/typing.js",
        "js/grammar.js",
        "js/summarize.js",
        "js/qrcode.min.js",
        "js/qr.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "save.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://lrclib.net/*",
    "https://translate.googleapis.com/*",
    "https://raw.githubusercontent.com/*",
    "https://api.datamuse.com/*",
    "https://api.languagetool.org/*",
    "https://api.groq.com/*",
    "https://api.openai.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.anthropic.com/*",
    "https://api.deepseek.com/*",
    "https://api.x.ai/*",
    "https://api.moonshot.ai/*",
    "https://dashscope-intl.aliyuncs.com/*",
    "http://127.0.0.1:11434/*",
    "http://127.0.0.1:5055/*",
    "http://localhost:5055/*"
  ],
  "offline_enabled": true
}

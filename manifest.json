{
  "manifest_version": 3,
  "name": "nyx",
  "version": "1.0.0",
  "description": "Glass start page: link groups, command mode (>), Alt+D dock, image/video wallpaper with auto colors.",
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "permissions": [ "contextMenus", "storage", "tabs", "webNavigation" ],
  "background": {
    "service_worker": "js/background.js"
  },
  "content_scripts": [
    {
      "matches": [ "<all_urls>" ],
      "js": [ "js/stashCore.js", "js/content.js", "js/vaultContent.js", "js/snippets.js", "js/qrcode.min.js", "js/qr.js" ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    { "resources": [ "save.html" ], "matches": [ "<all_urls>" ] }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "host_permissions": [
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "http://127.0.0.1:5055/*",
    "http://localhost:5055/*"
  ],
  "offline_enabled": true
}
